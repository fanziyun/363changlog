{
  "schemaVersion": 1,
  "id": "changelog363",
  "version": "${version}",
  "name": "363Changelog",
  "description": "更新日志模组 - 在标题界面展示整合包更新日志",
  "authors": ["FanZiyun"],
  "contact": {
    "homepage": "https://github.com/FanZiyun"
  },
  "license": "MIT",
  "icon": "assets/changelog363/icon.png",
  "environment": "client",
"entrypoints": {
    "client": [
      "com.github.fanziyun.client.ChangelogClient"
    ],
    "main": [
      "com.github.fanziyun.Changelog"
    ],
    "modmenu": [
      "com.github.fanziyun.client.ModMenuIntegration"
    ]
  },
  "mixins": [
    "changelog363.mixins.json",
    {
      "config": "changelog363.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-language-kotlin": ">=${kotlin_loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}",
    "cloth-config": "*",
    "modmenu": "*"
  }
}
